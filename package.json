{
  "name": "chess-club-v2",
  "version": "0.1.0",
  "description": "Chess club platform, rebuilt clean on Cloudflare (Workers + D1 + Durable Objects). Vanilla frontend with a small esbuild build step and shared components.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch & wrangler dev",
    "deploy": "node build.mjs && wrangler deploy",
    "db:migrate": "node tools/migrate.mjs",
    "db:migrate:remote": "node tools/migrate.mjs --remote",
    "db:seed": "wrangler d1 execute chess-club-v2-db --local --file schema/seed_puzzles.sql",
    "db:seed:remote": "wrangler d1 execute chess-club-v2-db --remote --file schema/seed_puzzles.sql",
    "db:init": "node tools/migrate.mjs",
    "db:init:remote": "node tools/migrate.mjs --remote"
  },
  "dependencies": {
    "chess.js": "^1.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "wrangler": "^3.114.0"
  }
}
